{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "dev",
      "label": "npm: dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(\\s*(?:Error:|ERROR|ERR!|✘|✖).*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "astro dev",
          "endsPattern": "watching for file changes"
        }
      }
    }
  ]
}
